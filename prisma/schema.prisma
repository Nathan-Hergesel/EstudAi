generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model users {
  id      String   @id @db.Uuid
  profile Profile?

  @@schema("auth")
}

model Profile {
  id            String        @id @db.Uuid
  nome          String
  email         String        @unique
  instituicao   String?
  curso         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  configuracoes Configuracao?
  horarios      Horario[]
  materias      Materia[]
  users         users         @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tarefas       Tarefa[]

  @@map("profiles")
  @@schema("public")
}

model Materia {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  nome      String
  codigo    String?
  professor String?
  cor       String?   @default("#2563EB")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  horarios  Horario[]
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tarefas   Tarefa[]

  @@index([userId], map: "idx_materias_user_id")
  @@map("materias")
  @@schema("public")
}

model Tarefa {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  materiaId   String?  @map("materia_id") @db.Uuid
  tipo        String
  titulo      String
  descricao   String
  dataEntrega DateTime @map("data_entrega") @db.Timestamptz(6)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  materia     Materia? @relation(fields: [materiaId], references: [id], onUpdate: NoAction)
  profile     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_tarefas_user_id")
  @@index([materiaId], map: "idx_tarefas_materia_id")
  @@index([dataEntrega], map: "idx_tarefas_data_entrega")
  @@index([completed], map: "idx_tarefas_completed")
  @@map("tarefas")
  @@schema("public")
}

model Horario {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  materiaId  String   @map("materia_id") @db.Uuid
  diaSemana  Int      @map("dia_semana")
  horaInicio DateTime @map("hora_inicio") @db.Time(6)
  horaFim    DateTime @map("hora_fim") @db.Time(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  materia    Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profile    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_horarios_user_id")
  @@index([diaSemana], map: "idx_horarios_dia_semana")
  @@map("horarios")
  @@schema("public")
}

model Configuracao {
  userId             String   @id @map("user_id") @db.Uuid
  notificacoesAtivas Boolean  @default(true) @map("notificacoes_ativas")
  lembreteTarefas    Boolean  @default(true) @map("lembrete_tarefas")
  alertaVencimento   Boolean  @default(true) @map("alerta_vencimento")
  horasAntecedencia  Int      @default(24) @map("horas_antecedencia")
  temaEscuro         Boolean  @default(false) @map("tema_escuro")
  mostrarConcluidas  Boolean  @default(true) @map("mostrar_concluidas")
  sincronizacaoAuto  Boolean  @default(true) @map("sincronizacao_auto")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("configuracoes")
  @@schema("public")
}
